# Windows без Docker: SQLite-файл в корне проекта.
DATABASE_URL=sqlite:///./intel.db
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9100

# false = реальный online-поиск по Рунету; true = добавлять mock-данные.
USE_MOCK_COLLECTOR=false
# Список запросов для онлайн-discovery в Рунете.
DISCOVERY_QUERIES=["site:vk.com помощь студентам курсовая", "site:t.me курсовая срочно", "где заказать дипломную работу форум", "антиплагиат поднять уникальность помощь"]

AIRTABLE_PAT=
AIRTABLE_BASE_ID=
NOTION_TOKEN=
GOOGLE_SERVICE_ACCOUNT_JSON=
TELEGRAM_BOT_TOKEN=
